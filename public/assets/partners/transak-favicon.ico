              try {
                // Check if consent has been given for targeting cookies (C0004)
                if (typeof window === 'undefined') {
                  return;
                }
                
                var hasConsent = false;
                
                // Check if C0004 (Targeting Cookies) is in active groups
                // OnetrustActiveGroups returns a string like ',C0001,C0002,C0003,C0004,'
                if (window.OnetrustActiveGroups && typeof window.OnetrustActiveGroups === 'string') {
                  hasConsent = window.OnetrustActiveGroups.indexOf(',C0004,') !== -1;
                  // console.log('hasConsent 1 =', hasConsent);
                }
                
                // console.log('hasConsent 0 =', hasConsent);
                if (hasConsent) {
                // console.log('hasConsent 2 =', hasConsent);
                  // Update Google Analytics consent mode
                  if (typeof window.gtag === 'function') {
                    window.gtag('consent', 'update', {
                      'analytics_storage': 'granted',
                      'ad_storage': 'granted'
                    });
                  }
                  
                  // Initialize Mixpanel if available
                  if (window.__initMixpanel && window.__mixpanelToken) {
                    window.__initMixpanel(window.__mixpanelToken);
                  }
                  
                  // HubSpot script is auto-unblocked by OneTrust's OtAutoBlock.js
                  // No additional initialization needed as it auto-initializes when unblocked
                } else {
                  // Consent not given - update GA consent to denied
                // console.log('hasConsent else  =', hasConsent);
                  if (typeof window.gtag === 'function') {
                    window.gtag('consent', 'update', {
                      'analytics_storage': 'denied',
                      'ad_storage': 'denied'
                    });
                  }
                }
              } catch (error) {
                console.warn('OptanonWrapper error:', error);
              }
            }</script><link rel="preload" href="https://assets.transak.com/static/website/_next/static/css/5c1675842fef007a.css" as="style"/><link rel="stylesheet" href="https://assets.transak.com/static/website/_next/static/css/5c1675842fef007a.css" data-n-g=""/><noscript data-n-css=""></noscript><script defer="" nomodule="" src="https://assets.transak.com/static/website/_next/static/chunks/polyfills-c67a75d1b6f99dc8.js"></script><script id="onetrust-autoblock" src="https://cdn.cookielaw.org/consent/d9cc2aee-36d3-4512-bb0b-93b9af792a07/OtAutoBlock.js" defer="" data-nscript="beforeInteractive"></script><script id="onetrust" src="https://cdn.cookielaw.org/scripttemplates/otSDKStub.js" data-domain-script="d9cc2aee-36d3-4512-bb0b-93b9af792a07" data-language="en" defer="" data-nscript="beforeInteractive"></script><script src="https://assets.transak.com/static/website/_next/static/chunks/webpack-62215ec66322fa00.js" defer=""></script><script src="https://assets.transak.com/static/website/_next/static/chunks/framework-533892bb65fd6f3c.js" defer=""></script><script src="https://assets.transak.com/static/website/_next/static/chunks/main-0e5b6395ea6b7ce3.js" defer=""></script><script src="https://assets.transak.com/static/website/_next/static/chunks/pages/_app-7bca9a05413731de.js" defer=""></script><script src="https://assets.transak.com/static/website/_next/static/chunks/pages/_error-aa326cc6a6d6eae3.js" defer=""></script><script src="https://assets.transak.com/static/website/_next/static/WOEDFPYDSgqgyFJWZER1i/_buildManifest.js" defer=""></script><script src="https://assets.transak.com/static/website/_next/static/WOEDFPYDSgqgyFJWZER1i/_ssgManifest.js" defer=""></script><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;300;400;500;600;700;800&display=swap"/></head><body><div id="__next"><nav style="background:#fff" class="main-navbar  navbar navbar-expand-xl navbar-light fixed-top"><div class="Header_navContainer__dDnsM container"><div cl